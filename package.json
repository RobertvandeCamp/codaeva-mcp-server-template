{
  "name": "{{SERVER_SLUG}}",
  "version": "1.0.0",
  "description": "{{DISPLAY_NAME}} MCP Server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "vite build && npm run copy-resources",
    "copy-resources": "mkdir -p dist/resources && cp src/resources/*.md dist/resources/",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "mcp",
    "typescript",
    "codaeva",
    "vite",
    "server"
  ],
  "author": "Codaeva",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@supabase/supabase-js": "^2.93.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jose": "^6.1.3",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.2",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.15"
  }
