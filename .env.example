PORT={{DEV_PORT}}
NODE_ENV=development
LOG_LEVEL=info

# Supabase connection
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Required when AUTH_DISABLED=true: Service role key for dev mode
SUPABASE_SERVICE_KEY=

# Auth configuration
# Set AUTH_DISABLED=true for local development without OAuth
AUTH_DISABLED=false

# Auth - derived from SUPABASE_URL if not set
# SUPABASE_JWKS_URL=https://xxx.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_ISSUER=https://xxx.supabase.co/auth/v1

# Auto-login mode (development only)
# AUTH_EMAIL=dev@example.com
# AUTH_PASSWORD=devpassword
